# Core app
PORT=5000
HOST=127.0.0.1
DATA_DIR=./data
SESSION_SECRET=

# Optional bootstrap for a fresh instance with empty data/users.json
DEFAULT_ADMIN_USERNAME=
DEFAULT_ADMIN_PASSWORD=

# External integrations
ANTHROPIC_API_KEY=
GEOIP_ACCOUNT_ID=
GEOIP_LICENSE_KEY=
GEOLITE2_ASN_DB_PATH=/var/lib/GeoIP/GeoLite2-ASN.mmdb
GEOLITE2_COUNTRY_DB_PATH=/var/lib/GeoIP/GeoLite2-Country.mmdb
IP_API_TIMEOUT_MS=1500
IP_API_BACKOFF_MS=60000
